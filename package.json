{
  "name": "tfg-walter",
  "private": true,
  "version": "1.0.0",
  "scripts": {
    "dev": "npm run dev:backend & npm run dev:frontend",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "start": "npm --prefix backend start",
    "build": "npm --prefix frontend run build",
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "db:up": "docker compose -f backend/docker-compose.yml up -d mysql",
    "db:migrate": "npm --prefix backend run db:migrate",
    "db:seed": "npm --prefix backend run db:seed",
    "test:backend": "npm --prefix backend run test",
    "test:frontend": "npm --prefix frontend run test",
    "test": "npm run test:backend && npm run test:frontend",
    "sonar": "npm run test && sonar-scanner"
  },
  "devDependencies": {
    "sonar-scanner": "^3.1.0"
  }
}
